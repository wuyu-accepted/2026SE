<view class="page">
  <view class="card">
    <view class="card-title">提交思想汇报</view>

    <view class="field">
      <view class="label">标题</view>
      <input class="input" value="{{form.title}}" placeholder="请输入标题" bindinput="onTitleInput" />
    </view>

    <view class="field">
      <view class="label">内容</view>
      <textarea class="textarea" value="{{form.content}}" placeholder="请输入内容（可选）" bindinput="onContentInput" />
    </view>

    <view class="field">
      <view class="label">附件（PDF/Word）</view>
      <view class="file-row">
        <button size="mini" bindtap="onChooseFile">选择文件</button>
        <view class="file-name">{{fileName || '未选择'}}</view>
      </view>
    </view>

    <view class="actions">
      <button class="primary" loading="{{submitting}}" bindtap="onSubmit">提交</button>
    </view>
  </view>

  <view class="card">
    <view class="card-title">我的思想汇报</view>
    <view wx:if="{{loadingList}}" class="muted">加载中...</view>
    <view wx:if="{{!loadingList && !reports.length}}" class="muted">暂无数据</view>

    <view wx:for="{{reports}}" wx:key="id" class="report-item">
      <view class="row">
        <view class="name">{{item.title}}</view>
        <view class="tag tag-{{item.status}}">{{item.statusText}}</view>
      </view>
      <view class="row muted">
        <view>提交：{{item.submitTime || '-'}}</view>
        <view wx:if="{{item.reviewedAt}}">审核：{{item.reviewedAt}}</view>
      </view>
      <view wx:if="{{item.reviewComment}}" class="muted">意见：{{item.reviewComment}}</view>
      <view class="row">
        <button wx:if="{{item.fileId}}" size="mini" bindtap="onOpenAttachment" data-fileid="{{item.fileId}}">查看附件</button>
      </view>
    </view>
  </view>
</view>
