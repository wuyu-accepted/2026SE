<view class="page">
  <view class="hero-card">
    <view class="hero-eyebrow">ACCOUNT LOGIN</view>
    <view class="hero-title">学院学生服务平台</view>
    <view class="hero-desc">使用学号和密码登录，后续业务数据将按个人账号独立保存。</view>
  </view>

  <view class="form-card">
    <view class="field">
      <view class="label">学号</view>
      <input class="input" type="number" placeholder="请输入数字学号" value="{{studentNo}}" bindinput="onStudentNoInput" />
    </view>
    <view class="field">
      <view class="label">密码</view>
      <input class="input" password placeholder="请输入密码" bindinput="onPasswordInput" />
    </view>
    <button class="primary-btn" loading="{{submitting}}" bindtap="onSubmit">登录</button>
    <view class="login-hint">账号由辅导员或管理员在管理端导入，请联系学院老师获取账号。</view>
  </view>
</view>
