.page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f0eb;
}

.hero {
  padding: 100rpx 40rpx 70rpx;
  background: linear-gradient(135deg, #BE1E2D 0%, #A01828 100%);
  text-align: center;
  position: relative;
  overflow: hidden;
}

.hero::after {
  content: '';
  position: absolute;
  top: -100rpx;
  right: -100rpx;
  width: 400rpx;
  height: 400rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.04);
}

.hero::before {
  content: '';
  position: absolute;
  bottom: -60rpx;
  left: -60rpx;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.03);
}

.hero-emblem {
  font-size: 48rpx;
  color: rgba(255,255,255,0.2);
  margin-bottom: 16rpx;
}

.hero-badge {
  font-size: 22rpx;
  letter-spacing: 6rpx;
  color: rgba(255,255,255,0.65);
  position: relative;
  z-index: 1;
}

.hero-title {
  margin-top: 24rpx;
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  position: relative;
  z-index: 1;
}

.hero-sub {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: rgba(255,255,255,0.75);
  position: relative;
  z-index: 1;
}

.card {
  margin: -44rpx 28rpx 0;
  padding: 44rpx 32rpx 36rpx;
  border-radius: 28rpx;
  background: #fff;
  box-shadow: 0 8rpx 32rpx rgba(190, 30, 45, 0.08);
  position: relative;
  z-index: 2;
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2c2c2c;
  margin-bottom: 36rpx;
  text-align: center;
  letter-spacing: 2rpx;
}

.field {
  margin-bottom: 28rpx;
}

.field-label {
  font-size: 24rpx;
  font-weight: 500;
  color: #6a6a6a;
  margin-bottom: 12rpx;
}

.field-input {
  height: 88rpx;
  padding: 0 28rpx;
  border-radius: 18rpx;
  background: #f7f3ef;
  font-size: 28rpx;
  width: 100%;
  color: #2c2c2c;
}

.field-input::placeholder {
  color: #c0b8b0;
}

.login-btn {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  border-radius: 46rpx;
  background: linear-gradient(135deg, #BE1E2D, #D43A4A);
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
  text-align: center;
  margin-top: 36rpx;
  border: none;
  box-shadow: 0 6rpx 24rpx rgba(190, 30, 45, 0.25);
}

.hint {
  margin-top: 24rpx;
  font-size: 22rpx;
  color: #b0b0b0;
  text-align: center;
}
