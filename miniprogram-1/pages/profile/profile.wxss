.page {
  min-height: 100vh;
  padding: 24rpx;
  background:
    radial-gradient(circle at top right, rgba(190, 30, 45, 0.08), transparent 30%),
    linear-gradient(180deg, #faf5f0 0%, #f5f0eb 100%);
}

.profile-card {
  padding: 36rpx 28rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #BE1E2D 0%, #D43A4A 100%);
  color: #ffffff;
}

.profile-eyebrow {
  font-size: 20rpx;
  letter-spacing: 4rpx;
  opacity: 0.7;
}

.profile-avatar-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-top: 20rpx;
}

.profile-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(255,255,255,0.3);
  flex-shrink: 0;
}

.avatar-btn {
  font-size: 24rpx;
  color: rgba(255,255,255,0.85);
  background: rgba(255,255,255,0.15);
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  line-height: 1;
}

.profile-name {
  margin-top: 18rpx;
  font-size: 40rpx;
  font-weight: 700;
}

.profile-meta,
.profile-id {
  margin-top: 10rpx;
  font-size: 24rpx;
  opacity: 0.9;
}

.section {
  margin-top: 20rpx;
  padding: 28rpx 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.section-last {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2c2c2c;
}

.section-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #6a6a6a;
}

.field {
  margin-top: 20rpx;
}

.label {
  font-size: 24rpx;
  font-weight: 700;
  color: #2c2c2c;
}

.input,
.picker,
.textarea {
  width: 100%;
  margin-top: 14rpx;
  border-radius: 18rpx;
  background: #faf5f0;
  font-size: 26rpx;
}

.input,
.picker {
  height: 84rpx;
  padding: 0 24rpx;
  line-height: 84rpx;
}

.input-disabled {
  color: #b0b0b0;
}

.textarea {
  min-height: 180rpx;
  padding: 22rpx 24rpx;
}

.save-btn,
.logout-btn {
  height: 84rpx;
  margin-top: 24rpx;
  border-radius: 42rpx;
  line-height: 84rpx;
}

.save-btn {
  color: #ffffff;
  background: linear-gradient(135deg, #BE1E2D, #D43A4A);
}

.logout-btn {
  color: #BE1E2D;
  background: rgba(190, 30, 45, 0.08);
}

.shortcut-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 20rpx;
}

.shortcut-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 24rpx;
  border-radius: 18rpx;
  background: #faf5f0;
}

.shortcut-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #2c2c2c;
}

.shortcut-action {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #BE1E2D;
  background: rgba(190, 30, 45, 0.1);
}
