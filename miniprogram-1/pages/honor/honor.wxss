.page {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f2f5f9;
  padding: 40rpx;
}

.card {
  width: 100%;
  padding: 60rpx 40rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.04);
  text-align: center;
}

.illus {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 16rpx;
}

.desc {
  font-size: 26rpx;
  color: #64748b;
  line-height: 1.6;
}

.back-btn {
  margin-top: 40rpx;
  padding: 20rpx 48rpx;
  border-radius: 44rpx;
  background: #123c63;
  color: #ffffff;
  font-size: 28rpx;
  display: inline-block;
}
