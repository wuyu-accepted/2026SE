.page {
  min-height: 100vh;
  background: #f5f0eb;
  padding: 24rpx;
}

.page-header {
  margin-bottom: 24rpx;
}

.page-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #2c2c2c;
}

.page-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #b0b0b0;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.honor-card {
  display: flex;
  gap: 20rpx;
  padding: 24rpx;
  border-radius: 22rpx;
  background: rgba(255,255,255,0.92);
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.04);
}

.honor-icon {
  font-size: 48rpx;
  flex-shrink: 0;
  width: 72rpx;
  text-align: center;
}

.honor-content {
  flex: 1;
}

.honor-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2c2c2c;
}

.honor-meta {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #8a8a8a;
}

.honor-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #6a6a6a;
  line-height: 1.6;
}

.empty {
  padding: 80rpx;
  text-align: center;
  font-size: 26rpx;
  color: #b0b0b0;
}
