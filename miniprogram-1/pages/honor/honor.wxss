.page {
  min-height: 100vh;
  background: #f2f5f9;
  padding: 24rpx;
}

.page-header {
  margin-bottom: 24rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #0f172a;
}

.page-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #64748b;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.honor-card {
  display: flex;
  gap: 20rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: rgba(255,255,255,0.92);
  box-shadow: 0 4rpx 16rpx rgba(30,41,59,0.04);
}

.honor-icon {
  font-size: 48rpx;
  flex-shrink: 0;
  width: 72rpx;
  text-align: center;
}

.honor-content {
  flex: 1;
}

.honor-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #0f172a;
}

.honor-meta {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #64748b;
}

.honor-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #475569;
  line-height: 1.6;
}

.empty {
  padding: 80rpx;
  text-align: center;
  font-size: 26rpx;
  color: #94a3b8;
}
