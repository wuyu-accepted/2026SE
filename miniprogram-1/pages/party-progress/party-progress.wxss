.page {
  min-height: 100vh;
  padding: 24rpx;
  background: #f6f6f6;
}

.summary-card,
.section {
  padding: 28rpx 24rpx;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, 0.06);
}

.summary-top,
.reminder-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.summary-name,
.section-title,
.reminder-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #0f172a;
}

.summary-meta,
.summary-info,
.reminder-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #64748b;
}

.summary-stage,
.summary-stage {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.summary-stage {
  color: #ffffff;
  background: #c8161d;
}

.summary-desc {
  margin-top: 18rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #334155;
}

.section {
  margin-top: 20rpx;
}

.section-last {
  margin-bottom: 24rpx;
}

.steps-scroll {
  margin-top: 18rpx;
  white-space: nowrap;
}

.steps-row {
  display: inline-flex;
  align-items: center;
  gap: 32rpx;
  padding: 10rpx 10rpx 10rpx 4rpx;
}

.step-item {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 140rpx;
}

.step-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #cbd5e1;
}

.step-dot.is-active {
  background: #c8161d;
}

.step-label {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: #64748b;
  text-align: center;
  line-height: 1.4;
}

.step-label.is-active {
  color: #c8161d;
  font-weight: 700;
}

.step-line {
  position: absolute;
  top: 9rpx;
  left: calc(50% + 78rpx);
  width: 64rpx;
  height: 2rpx;
  background: #e2e8f0;
}

.info-table {
  margin-top: 18rpx;
  border-radius: 16rpx;
  background: #f8fafc;
  overflow: hidden;
}

.info-row {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  padding: 22rpx 20rpx;
  border-bottom: 1rpx solid rgba(15, 23, 42, 0.06);
}

.info-row:last-child {
  border-bottom: none;
}

.info-key {
  flex-shrink: 0;
  width: 140rpx;
  font-size: 24rpx;
  color: #475569;
}

.info-value {
  flex: 1;
  font-size: 24rpx;
  color: #0f172a;
  text-align: right;
  line-height: 1.6;
}

.reminder-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 18rpx;
}

.reminder-card {
  padding: 22rpx;
  border-radius: 16rpx;
  background: #fff7f7;
  border: 1rpx solid rgba(200, 22, 29, 0.14);
}

.reminder-icon {
  flex-shrink: 0;
  width: 44rpx;
  height: 44rpx;
  border-radius: 999rpx;
  background: rgba(200, 22, 29, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
}

.materials {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx dashed rgba(200, 22, 29, 0.22);
}

.materials-title {
  font-size: 24rpx;
  font-weight: 700;
  color: #0f172a;
}

.materials-list {
  margin-top: 10rpx;
}

.materials-item {
  font-size: 24rpx;
  line-height: 1.7;
  color: #475569;
}

.empty-card {
  margin-top: 18rpx;
  padding: 22rpx;
  border-radius: 16rpx;
  background: #f8fafc;
  color: #64748b;
  font-size: 24rpx;
}
