.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f2f5f9;
}
.chat-scroll {
  flex: 1;
  padding: 20rpx;
}
.message-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.message-item {
  display: flex;
}
.message-item.user {
  justify-content: flex-end;
}
.message-item.assistant {
  justify-content: flex-start;
}
.bubble {
  max-width: 86%;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(15, 23, 42, 0.06);
}
.message-item.user .bubble {
  background: #1677ff;
  color: #fff;
}
.bubble-text {
  white-space: pre-wrap;
  font-size: 28rpx;
  line-height: 1.7;
}
.section {
  margin-top: 16rpx;
}
.section-title {
  font-size: 24rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}
.citation-card {
  background: #f8fafc;
  border-radius: 12rpx;
  padding: 16rpx;
  margin-bottom: 12rpx;
}
.citation-title {
  font-size: 26rpx;
  font-weight: 600;
}
.citation-type {
  display: inline-block;
  margin-right: 8rpx;
  padding: 2rpx 8rpx;
  border-radius: 6rpx;
  background: #e8f1ff;
  color: #2454a6;
  font-size: 20rpx;
  font-weight: 500;
}
.citation-summary {
  font-size: 24rpx;
  color: #64748b;
  margin-top: 6rpx;
}
.action-btn {
  margin: 0 0 12rpx 0;
  background: #e8f1ff;
  color: #123c63;
  border-radius: 999rpx;
  font-size: 24rpx;
}
.fallback-tip {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #8c8c8c;
}
.composer {
  display: flex;
  gap: 16rpx;
  padding: 20rpx;
  background: #fff;
  border-top: 1rpx solid #e5e7eb;
  align-items: center;
}
.input {
  flex: 1;
  min-width: 0;
  background: #f8fafc;
  border-radius: 999rpx;
  padding: 0 24rpx;
  height: 80rpx;
}
.send-btn {
  flex: 0 0 64rpx;
  width: 64rpx;
  height: 64rpx;
  padding: 0;
  margin: 0;
  background: #1677ff;
  color: #fff;
  border-radius: 50%;
  font-size: 34rpx;
  line-height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.send-btn.is-loading {
  background: #94a3b8;
  color: #fff;
}
.send-icon {
  line-height: 1;
  transform: translateY(-2rpx);
}
