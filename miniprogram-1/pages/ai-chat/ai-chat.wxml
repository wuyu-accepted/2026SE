<view class="page">
  <scroll-view class="chat-scroll" scroll-y>
    <view class="message-list">
      <view wx:for="{{messages}}" wx:key="index" wx:for-item="item" class="message-item {{item.role}}">
        <view class="bubble">
          <view class="bubble-text">{{item.content}}</view>
          <view wx:if="{{item.fallback}}" class="fallback-tip">已自动降级为知识检索结果</view>
          <view wx:if="{{item.citations && item.citations.length}}" class="section">
            <view class="section-title">引用知识</view>
            <view class="citation-card" wx:for="{{item.citations}}" wx:for-item="cit" wx:key="id" data-id="{{cit.id}}" bindtap="handleCitationTap">
              <view class="citation-title">{{cit.title}}</view>
              <view class="citation-summary">{{cit.summary}}</view>
            </view>
          </view>
          <view wx:if="{{item.actions && item.actions.length}}" class="section">
            <view class="section-title">相关入口</view>
            <button
              wx:for="{{item.actions}}"
              wx:for-item="act"
              wx:key="code"
              class="action-btn"
              data-path="{{act.path}}"
              data-tabpage="{{act.tabPage}}"
              bindtap="handleActionTap"
            >
              进入 {{act.title}}
            </button>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>

  <view class="composer">
    <input class="input" value="{{inputValue}}" placeholder="问我：我想请假怎么办？" bindinput="onInput" confirm-type="send" bindconfirm="sendMessage" />
    <view class="send-btn {{loading ? 'is-loading' : ''}}" bindtap="sendMessage">
      <text class="send-icon">{{loading ? '…' : '↑'}}</text>
    </view>
  </view>
</view>
