.page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top right, rgba(190, 30, 45, 0.05), transparent 30%),
    linear-gradient(180deg, #faf5f0 0%, #f5f0eb 52%, #efe8e0 100%);
}

.page-scroll {
  height: 100vh;
  padding: 24rpx 24rpx 48rpx;
}

.block-card {
  margin-top: 20rpx;
  padding: 28rpx 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.block-head {
  margin-bottom: 20rpx;
}

.block-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #2c2c2c;
}

.block-subtitle {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #b0b0b0;
}

.grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
}

.grid-item {
  padding: 24rpx 12rpx;
  border-radius: 18rpx;
  background: #ffffff;
  border: 1rpx solid rgba(0, 0, 0, 0.04);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
}

.grid-item-hover {
  background: #faf5f0;
  transform: scale(0.96);
}

.icon-badge {
  width: 76rpx;
  height: 76rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
}

.grid-text {
  font-size: 22rpx;
  color: #2c2c2c;
  text-align: center;
  font-weight: 500;
}

.icon-blue { background: rgba(190, 30, 45, 0.08); }
.icon-indigo { background: rgba(26, 60, 106, 0.08); }
.icon-teal { background: rgba(26, 60, 106, 0.08); }
.icon-orange { background: rgba(190, 30, 45, 0.1); }
.icon-cyan { background: rgba(26, 60, 106, 0.06); }
.icon-green { background: rgba(26, 60, 106, 0.08); }
.icon-purple { background: rgba(190, 30, 45, 0.06); }
.icon-pink { background: rgba(190, 30, 45, 0.08); }
