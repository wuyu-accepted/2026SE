.page {
  min-height: 100vh;
  background: #f6f6f6;
}

.page-scroll {
  height: 100vh;
  padding: 24rpx 24rpx 48rpx;
}

.block-card {
  margin-top: 20rpx;
  padding: 28rpx 24rpx;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, 0.06);
}

.block-head {
  margin-bottom: 18rpx;
}

.block-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #0f172a;
}

.block-subtitle {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #64748b;
}

.grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16rpx;
}

.grid-item {
  padding: 22rpx 16rpx;
  border-radius: 16rpx;
  background: #ffffff;
  border: 1rpx solid rgba(15, 23, 42, 0.06);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
}

.grid-item-hover {
  background: #f3f4f6;
}

.icon-badge {
  width: 88rpx;
  height: 88rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #0f172a;
}

.grid-text {
  font-size: 24rpx;
  color: #0f172a;
  text-align: center;
}

.icon-blue {
  background: rgba(59, 130, 246, 0.14);
}

.icon-indigo {
  background: rgba(99, 102, 241, 0.14);
}

.icon-teal {
  background: rgba(13, 148, 136, 0.14);
}

.icon-orange {
  background: rgba(234, 88, 12, 0.14);
}

.icon-cyan {
  background: rgba(6, 182, 212, 0.14);
}

.icon-green {
  background: rgba(22, 163, 74, 0.14);
}

.icon-purple {
  background: rgba(147, 51, 234, 0.14);
}

.icon-pink {
  background: rgba(236, 72, 153, 0.14);
}
