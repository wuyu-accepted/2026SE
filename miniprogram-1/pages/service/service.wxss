.page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top right, rgba(56, 189, 248, 0.08), transparent 30%),
    linear-gradient(180deg, #f6fbff 0%, #f3f6fb 52%, #edf2f7 100%);
}

.page-scroll {
  height: 100vh;
  padding: 24rpx 24rpx 48rpx;
}

.block-card {
  margin-top: 20rpx;
  padding: 28rpx 24rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.04);
  backdrop-filter: blur(8rpx);
}

.block-head {
  margin-bottom: 20rpx;
}

.block-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
}

.block-subtitle {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #94a3b8;
}

.grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
}

.grid-item {
  padding: 24rpx 12rpx;
  border-radius: 20rpx;
  background: #ffffff;
  border: 1rpx solid rgba(15, 23, 42, 0.04);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  transition: all 0.2s;
}

.grid-item-hover {
  background: #f8fafc;
  transform: scale(0.96);
}

.icon-badge {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.grid-text {
  font-size: 22rpx;
  color: #0f172a;
  text-align: center;
  font-weight: 500;
}

.icon-blue {
  background: rgba(59, 130, 246, 0.12);
}

.icon-indigo {
  background: rgba(99, 102, 241, 0.12);
}

.icon-teal {
  background: rgba(13, 148, 136, 0.12);
}

.icon-orange {
  background: rgba(234, 88, 12, 0.12);
}

.icon-cyan {
  background: rgba(6, 182, 212, 0.12);
}

.icon-green {
  background: rgba(22, 163, 74, 0.12);
}

.icon-purple {
  background: rgba(147, 51, 234, 0.12);
}

.icon-pink {
  background: rgba(236, 72, 153, 0.12);
}
