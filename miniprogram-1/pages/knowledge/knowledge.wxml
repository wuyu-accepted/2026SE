<view class="page">
  <view class="search-card">
    <view class="search-title">知识库</view>
    <view class="search-desc">查询政策说明、办事指南与常见问题。</view>
    <input
      class="search-input"
      placeholder="搜索文章标题、摘要关键词"
      bindinput="onKeywordInput"
    />
  </view>

  <view wx:if="{{recommendations.length}}" class="section recommend-section">
    <view class="section-title">为你推荐</view>
    <view class="section-desc">根据你的年级、党团阶段、待办和近期行为生成。</view>
    <view class="article-list">
      <view
        wx:for="{{recommendations}}"
        wx:key="id"
        class="article-card recommend-card"
        data-id="{{item.id}}"
        data-target-type="{{item.targetType}}"
        data-file-id="{{item.fileId}}"
        bindtap="onRecommendationTap"
      >
        <view class="article-head">
          <view class="article-category">{{item.targetType === 'template' ? '模板' : '知识'}}</view>
          <view class="article-source">推荐</view>
        </view>
        <view class="article-title">{{item.title}}</view>
        <view class="article-summary">{{item.summary}}</view>
        <view class="recommend-reason">{{item.reason}}</view>
        <view wx:if="{{item.tags.length}}" class="tag-row">
          <view wx:for="{{item.tags}}" wx:key="*this" class="tag-chip">{{item}}</view>
        </view>
      </view>
    </view>
  </view>

  <scroll-view class="chips-scroll" scroll-x>
    <view class="chips-row">
      <view
        wx:for="{{categories}}"
        wx:key="*this"
        class="chip {{selectedCategory === item ? 'chip-active' : ''}}"
        data-category="{{item}}"
        bindtap="onCategoryTap"
      >
        {{item}}
      </view>
    </view>
  </scroll-view>

  <view class="section">
    <view class="section-title">文章列表</view>
    <view class="section-desc">点击卡片可查看详情。</view>
    <view wx:if="{{visibleArticles.length}}" class="article-list">
      <view wx:for="{{visibleArticles}}" wx:key="id" class="article-card" data-id="{{item.id}}" bindtap="onArticleTap">
        <view class="article-head">
          <view class="article-category">{{item.category}}</view>
          <view class="article-source">{{item.source}}</view>
        </view>
        <view class="article-title">{{item.title}}</view>
        <view class="article-summary">{{item.summary}}</view>
        <view wx:if="{{item.tagText}}" class="article-tags">{{item.tagText}}</view>
        <view class="article-answer">{{item.answer}}</view>
      </view>
    </view>
    <view wx:else class="empty-card">暂无匹配结果</view>
  </view>
</view>
