.page {
  min-height: 100vh;
  padding: 24rpx;
  background: #f5f0eb;
}

.search-card,
.section {
  padding: 28rpx 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.search-title,
.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2c2c2c;
}

.search-desc,
.section-desc,
.article-summary,
.article-answer,
.template-desc,
.empty-card {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #8a8a8a;
}

.search-input {
  height: 84rpx;
  margin-top: 24rpx;
  padding: 0 24rpx;
  border-radius: 20rpx;
  background: #f7f3ef;
  font-size: 26rpx;
  color: #2c2c2c;
}

.search-input::placeholder {
  color: #c0b8b0;
}

.chips-scroll {
  margin: 20rpx 0;
  white-space: nowrap;
}

.chips-row {
  display: inline-flex;
  gap: 14rpx;
  padding-right: 24rpx;
}

.chip {
  padding: 14rpx 26rpx;
  border-radius: 999rpx;
  background: #f0e8e0;
  color: #6a6a6a;
  font-size: 24rpx;
}

.chip-active {
  background: #BE1E2D;
  color: #ffffff;
}

.section {
  margin-top: 20rpx;
}

.article-list,
.template-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 20rpx;
}

.article-card,
.template-card,
.empty-card {
  padding: 24rpx;
  border-radius: 18rpx;
  background: #faf6f3;
}

.article-head,
.template-card {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.article-category {
  font-size: 20rpx;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  color: #1A3C6A;
  background: rgba(26, 60, 106, 0.08);
}

.article-source {
  font-size: 20rpx;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  color: #BE1E2D;
  background: rgba(190, 30, 45, 0.06);
}

.article-title,
.template-name {
  margin-top: 18rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #2c2c2c;
}

.template-format {
  flex-shrink: 0;
  align-self: flex-start;
  font-size: 20rpx;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  color: #1A3C6A;
  background: rgba(26, 60, 106, 0.08);
}

.recommend-section {
  border: 2rpx solid rgba(190, 30, 45, 0.06);
}

.recommend-card {
  background: linear-gradient(180deg, #fef9f6 0%, #fdf0ec 100%);
}

.recommend-reason,
.article-tags {
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #BE1E2D;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.tag-chip {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  color: #6a6a6a;
  background: rgba(0, 0, 0, 0.04);
}

.search-state {
  margin-top: 14rpx;
  font-size: 22rpx;
  color: #1A3C6A;
}

.search-state.warning {
  color: #BE1E2D;
}

.search-tips {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-top: 16rpx;
}

.search-tip,
.article-highlight {
  margin-top: 12rpx;
  padding: 12rpx 16rpx;
  border-radius: 14rpx;
  background: rgba(190, 30, 45, 0.04);
  color: #BE1E2D;
  font-size: 22rpx;
  line-height: 1.6;
}
