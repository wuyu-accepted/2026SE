<view class="page">
  <view class="header-card">
    <view class="avatar">{{(profile && profile.realName) ? profile.realName.slice(0, 1) : '?'}}</view>
    <view class="header-info">
      <view class="header-name">{{profile && profile.realName}}</view>
      <view class="header-meta">{{profile && profile.major}} · {{profile && profile.className}}</view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">基本信息</view>
    <view class="info-row" wx:for="{{infoFields}}" wx:key="label" wx:if="{{profile}}">
      <view class="info-label">{{item.label}}</view>
      <view class="info-value">{{profile[item.key] || '未设置'}}</view>
    </view>
  </view>

  <view class="section section-last" wx:if="{{profile && profile.bio}}">
    <view class="section-title">个人简介</view>
    <view class="bio-text">{{profile.bio}}</view>
  </view>
</view>
