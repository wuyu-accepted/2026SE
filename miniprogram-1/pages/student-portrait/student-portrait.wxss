.page {
  min-height: 100vh;
  background: #f2f5f9;
  padding: 24rpx;
}

.header-card {
  padding: 40rpx 32rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #123c63 0%, #1f6f8b 100%);
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.2);
  flex-shrink: 0;
}

.header-info {
  flex: 1;
}

.header-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}

.header-meta {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
}

.section {
  margin-top: 24rpx;
  padding: 28rpx 24rpx;
  border-radius: 28rpx;
  background: rgba(255,255,255,0.92);
  box-shadow: 0 8rpx 24rpx rgba(30,41,59,0.04);
}

.section-last {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 20rpx;
}

.info-row {
  display: flex;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  width: 160rpx;
  font-size: 26rpx;
  color: #64748b;
  flex-shrink: 0;
}

.info-value {
  flex: 1;
  font-size: 26rpx;
  color: #0f172a;
}

.bio-text {
  font-size: 26rpx;
  color: #475569;
  line-height: 1.8;
}

.form-card {
  padding: 24rpx;
  border-radius: 24rpx;
  background: #f8fafc;
  margin-top: 20rpx;
}

.form-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 16rpx;
}

.field {
  margin-bottom: 16rpx;
}

.label {
  font-size: 22rpx;
  color: #64748b;
  margin-bottom: 8rpx;
}

.input {
  background: rgba(255,255,255,0.92);
  border-radius: 16rpx;
  padding: 16rpx;
  font-size: 26rpx;
  color: #0f172a;
}

.term-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.term-input {
  flex: 1;
}

.term-btn {
  flex-shrink: 0;
  padding: 0 18rpx;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #123c63;
  background: rgba(18, 60, 99, 0.12);
}

.textarea {
  background: rgba(255,255,255,0.92);
  border-radius: 16rpx;
  padding: 16rpx;
  font-size: 26rpx;
  color: #0f172a;
  min-height: 140rpx;
}

.hint {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #64748b;
  line-height: 1.7;
}

.submit-btn {
  margin-top: 12rpx;
  background: #2563eb;
  color: #fff;
  border-radius: 999rpx;
  font-size: 28rpx;
}

.group-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.term-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #0f172a;
  margin: 10rpx 0;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.honor-card {
  display: flex;
  gap: 20rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: rgba(255,255,255,0.92);
  box-shadow: 0 4rpx 16rpx rgba(30,41,59,0.04);
}

.honor-icon {
  font-size: 48rpx;
  flex-shrink: 0;
  width: 72rpx;
  text-align: center;
}

.honor-content {
  flex: 1;
}

.honor-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #0f172a;
}

.honor-meta {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #64748b;
}

.honor-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #475569;
  line-height: 1.6;
}

.honor-actions {
  display: flex;
  align-items: flex-start;
}

.action {
  font-size: 24rpx;
  color: #ef4444;
  padding: 10rpx 12rpx;
}

.empty {
  padding: 40rpx 0;
  text-align: center;
  font-size: 26rpx;
  color: #94a3b8;
}
