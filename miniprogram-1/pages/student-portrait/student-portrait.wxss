.page {
  min-height: 100vh;
  background: #f2f5f9;
  padding: 24rpx;
}

.header-card {
  padding: 40rpx 32rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #123c63 0%, #1f6f8b 100%);
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.2);
  color: #fff;
  font-size: 44rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.header-info {
  flex: 1;
}

.header-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}

.header-meta {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
}

.section {
  margin-top: 24rpx;
  padding: 28rpx 24rpx;
  border-radius: 28rpx;
  background: rgba(255,255,255,0.92);
  box-shadow: 0 8rpx 24rpx rgba(30,41,59,0.04);
}

.section-last {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 20rpx;
}

.info-row {
  display: flex;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  width: 160rpx;
  font-size: 26rpx;
  color: #64748b;
  flex-shrink: 0;
}

.info-value {
  flex: 1;
  font-size: 26rpx;
  color: #0f172a;
}

.bio-text {
  font-size: 26rpx;
  color: #475569;
  line-height: 1.8;
}
