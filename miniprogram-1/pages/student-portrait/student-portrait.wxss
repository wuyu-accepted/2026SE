.page {
  min-height: 100vh;
  padding: 24rpx;
  background: #f6f6f6;
  display: flex;
  align-items: center;
  justify-content: center;
}

.card {
  width: 100%;
  padding: 48rpx 32rpx;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, 0.06);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.illus {
  width: 140rpx;
  height: 140rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  background: rgba(147, 51, 234, 0.14);
}

.title {
  margin-top: 28rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #0f172a;
}

.desc {
  margin-top: 14rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #64748b;
  text-align: center;
}
