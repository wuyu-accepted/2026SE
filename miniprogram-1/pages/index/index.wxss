.page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top right, rgba(56, 189, 248, 0.14), transparent 30%),
    linear-gradient(180deg, #f6fbff 0%, #f3f6fb 52%, #edf2f7 100%);
}

.page-scroll {
  height: 100vh;
  box-sizing: border-box;
  padding: 32rpx 24rpx 48rpx;
}

.hero-card {
  padding: 40rpx 32rpx 32rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #123c63 0%, #1f6f8b 100%);
  color: #ffffff;
  box-shadow: 0 24rpx 48rpx rgba(18, 60, 99, 0.18);
}

.hero-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.hero-copy {
  flex: 1;
}

.hero-eyebrow {
  font-size: 22rpx;
  letter-spacing: 4rpx;
  opacity: 0.72;
}

.hero-title {
  margin-top: 16rpx;
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.28;
}

.hero-subtitle {
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.7;
  opacity: 0.9;
}

.hero-search {
  display: flex;
  gap: 16rpx;
  align-items: center;
  margin-top: 28rpx;
}

.hero-search-input {
  flex: 1;
  height: 76rpx;
  padding: 0 24rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.14);
  color: #fff;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
}

.hero-search-input::placeholder {
  color: rgba(255, 255, 255, 0.75);
}

.hero-search-button {
  flex-shrink: 0;
  padding: 0 28rpx;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.18);
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
}

.hero-meta {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 20rpx;
  margin-top: 32rpx;
}

.hero-meta-item {
  padding: 22rpx 18rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.1);
}

.hero-meta-value {
  font-size: 34rpx;
  font-weight: 700;
}

.hero-meta-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  opacity: 0.8;
}

.section {
  margin-top: 28rpx;
  padding: 28rpx 24rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 18rpx 40rpx rgba(30, 41, 59, 0.06);
  backdrop-filter: blur(8rpx);
}

.section-last {
  margin-bottom: 24rpx;
}

.section-head {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #0f172a;
}

.section-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #64748b;
}

.entry-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.entry-card {
  min-height: 188rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #f8fbff 0%, #eef6ff 100%);
}

.entry-icon {
  font-size: 40rpx;
}

.entry-title {
  margin-top: 18rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
}

.entry-desc {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #475569;
}

.stats-row {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 16rpx;
}

.stat-card {
  padding: 24rpx 18rpx;
  border-radius: 24rpx;
  background: #f8fafc;
}

.stat-value {
  font-size: 42rpx;
  font-weight: 700;
  color: #0f172a;
}

.stat-label {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #334155;
}

.stat-hint {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #94a3b8;
}

.notice-list,
.download-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.notice-card,
.download-card,
.empty-card {
  padding: 24rpx;
  border-radius: 24rpx;
  background: #f8fafc;
}

.notice-top,
.download-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.notice-tag {
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  color: #155e75;
  background: rgba(34, 211, 238, 0.18);
}

.notice-date {
  font-size: 22rpx;
  color: #94a3b8;
}

.notice-title,
.download-name,
.highlight-title {
  margin-top: 14rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #0f172a;
}

.notice-summary,
.download-desc,
.highlight-desc {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #475569;
}

.download-action {
  flex-shrink: 0;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(15, 118, 110, 0.12);
  color: #0f766e;
  font-size: 22rpx;
}
