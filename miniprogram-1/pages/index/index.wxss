.page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top right, rgba(56, 189, 248, 0.1), transparent 30%),
    linear-gradient(180deg, #f6fbff 0%, #f3f6fb 52%, #edf2f7 100%);
}

.page-scroll {
  height: 100vh;
  box-sizing: border-box;
  padding: 0 24rpx 48rpx;
}

.banner-swiper {
  margin-top: 20rpx;
  height: 300rpx;
  border-radius: 28rpx;
  overflow: hidden;
}

.banner-slide {
  width: 100%;
  height: 300rpx;
  display: flex;
  align-items: center;
  padding: 0 36rpx;
}

.banner-c0 {
  background: linear-gradient(135deg, #123c63 0%, #1f6f8b 100%);
}

.banner-c1 {
  background: linear-gradient(135deg, #0f766e 0%, #14b8a6 100%);
}

.banner-c2 {
  background: linear-gradient(135deg, #7c3aed 0%, #a78bfa 100%);
}

.banner-content {
  width: 100%;
}

.banner-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #ffffff;
  line-height: 1.3;
}

.banner-subtitle {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.6;
}

.search-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 20rpx;
  padding: 0 24rpx;
  height: 84rpx;
  border-radius: 42rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 4rpx 16rpx rgba(18, 60, 99, 0.06);
}

.search-input {
  flex: 1;
  height: 100%;
  font-size: 26rpx;
  color: #0f172a;
}

.search-input::placeholder {
  color: #94a3b8;
}

.search-icon {
  font-size: 32rpx;
  flex-shrink: 0;
}

.section {
  margin-top: 24rpx;
  padding: 28rpx 24rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 8rpx 24rpx rgba(30, 41, 59, 0.04);
  backdrop-filter: blur(8rpx);
}

.section-last {
  margin-bottom: 24rpx;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #0f172a;
}

.section-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.section-desc {
  font-size: 22rpx;
  color: #94a3b8;
}

.add-btn {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: rgba(18, 60, 99, 0.1);
  color: #123c63;
  font-size: 32rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.entry-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16rpx;
}

.entry-card {
  position: relative;
  min-height: 160rpx;
  padding: 20rpx 16rpx;
  border-radius: 20rpx;
  background: linear-gradient(180deg, #f8fbff 0%, #eef6ff 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.entry-icon {
  font-size: 40rpx;
}

.entry-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #0f172a;
}

.entry-hover {
  opacity: 0.8;
  transform: scale(0.96);
}

.empty-entry {
  padding: 48rpx 24rpx;
  border-radius: 20rpx;
  border: 2rpx dashed #cbd5e1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.empty-entry-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(18, 60, 99, 0.08);
  color: #123c63;
  font-size: 40rpx;
  font-weight: 300;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-entry-text {
  font-size: 24rpx;
  color: #64748b;
}

.stats-row {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12rpx;
}

.stat-card {
  padding: 20rpx 12rpx;
  border-radius: 20rpx;
  background: #f8fafc;
  text-align: center;
}

.stat-value {
  font-size: 38rpx;
  font-weight: 700;
  color: #123c63;
}

.stat-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #334155;
}

.stat-hint {
  margin-top: 6rpx;
  font-size: 18rpx;
  color: #94a3b8;
}

.notice-list,
.download-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.notice-card,
.download-card,
.empty-card {
  padding: 22rpx;
  border-radius: 20rpx;
  background: #f8fafc;
}

.notice-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.notice-tag {
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  color: #155e75;
  background: rgba(34, 211, 238, 0.18);
}

.notice-date {
  font-size: 20rpx;
  color: #94a3b8;
}

.notice-title,
.download-name {
  margin-top: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #0f172a;
}

.notice-summary,
.download-desc {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #475569;
}

.download-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.download-action {
  flex-shrink: 0;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(18, 60, 99, 0.1);
  color: #123c63;
  font-size: 22rpx;
  font-weight: 500;
}

.ai-fab {
  position: fixed;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 76rpx;
  height: 76rpx;
  border-radius: 38rpx;
  background: linear-gradient(135deg, #1677ff, #4f9cff);
  color: #fff;
  font-size: 26rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 20rpx rgba(22, 119, 255, 0.28);
  z-index: 20;
}
