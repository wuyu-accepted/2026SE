.page {
  min-height: 100vh;
  background: #f5f0eb;
}

.page-scroll {
  height: 100vh;
  box-sizing: border-box;
  padding: 0 24rpx 48rpx;
}

/* 轮播图 */
.banner-swiper {
  margin-top: 20rpx;
  height: 300rpx;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(190, 30, 45, 0.12);
}

.banner-slide {
  width: 100%;
  height: 300rpx;
  display: flex;
  align-items: center;
  padding: 0 36rpx;
}

.banner-c0 {
  background: linear-gradient(135deg, #BE1E2D 0%, #D43A4A 100%);
}

.banner-c1 {
  background: linear-gradient(135deg, #1A3C6A 0%, #2E5A8A 100%);
}

.banner-c2 {
  background: linear-gradient(135deg, #8B1A2B 0%, #BE1E2D 100%);
}

.banner-content {
  width: 100%;
}

.banner-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #ffffff;
  line-height: 1.3;
  text-shadow: 0 1rpx 4rpx rgba(0,0,0,0.1);
}

.banner-subtitle {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.5;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 24rpx;
  padding: 0 28rpx;
  height: 88rpx;
  border-radius: 44rpx;
  background: #ffffff;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.search-input {
  flex: 1;
  height: 100%;
  font-size: 26rpx;
  color: #2c2c2c;
}

.search-input::placeholder {
  color: #c0b8b0;
}

.search-icon {
  font-size: 32rpx;
  flex-shrink: 0;
}

/* 通用卡片区块 */
.section {
  margin-top: 24rpx;
  padding: 28rpx 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.section-last {
  margin-bottom: 24rpx;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2c2c2c;
}

.section-actions {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.section-desc {
  font-size: 22rpx;
  color: #b0b0b0;
}

/* 快捷入口编辑按钮 */
.add-btn {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: rgba(190, 30, 45, 0.08);
  color: #BE1E2D;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

/* 快捷入口网格 */
.entry-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
}

.entry-card {
  min-height: 140rpx;
  padding: 20rpx 14rpx;
  border-radius: 18rpx;
  background: #faf6f3;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.entry-hover {
  opacity: 0.8;
  transform: scale(0.96);
}

.entry-icon {
  font-size: 40rpx;
}

.entry-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #2c2c2c;
}

/* 空状态 */
.empty-entry {
  padding: 48rpx 24rpx;
  border-radius: 18rpx;
  border: 2rpx dashed #d8d0c8;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.empty-entry-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(190, 30, 45, 0.06);
  color: #BE1E2D;
  font-size: 40rpx;
  font-weight: 300;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-entry-text {
  font-size: 24rpx;
  color: #b0b0b0;
}

/* 待办统计 */
.stats-row {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12rpx;
}

.stat-card {
  padding: 20rpx 10rpx;
  border-radius: 16rpx;
  background: #faf6f3;
  text-align: center;
}

.stat-value {
  font-size: 34rpx;
  font-weight: 700;
  color: #BE1E2D;
}

.stat-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
  color: #4a4a4a;
}

.stat-hint {
  margin-top: 4rpx;
  font-size: 18rpx;
  color: #c0b8b0;
}

/* 通知列表 */
.notice-list,
.download-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.notice-card {
  padding: 22rpx 20rpx;
  border-radius: 18rpx;
  background: #faf6f3;
}

.notice-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.notice-tag {
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  color: #BE1E2D;
  background: rgba(190, 30, 45, 0.08);
}

.notice-date {
  font-size: 20rpx;
  color: #c0b8b0;
}

.notice-title {
  margin-top: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #2c2c2c;
  line-height: 1.4;
}

.notice-summary {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: #8a8a8a;
}

/* 下载列表 */
.download-card {
  padding: 22rpx 20rpx;
  border-radius: 18rpx;
  background: #faf6f3;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.download-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #2c2c2c;
}

.download-desc {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #8a8a8a;
}

.download-action {
  flex-shrink: 0;
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(190, 30, 45, 0.08);
  color: #BE1E2D;
  font-size: 22rpx;
  font-weight: 500;
}

.empty-card {
  padding: 22rpx;
  border-radius: 18rpx;
  background: #faf6f3;
  font-size: 24rpx;
  color: #b0b0b0;
  text-align: center;
}
