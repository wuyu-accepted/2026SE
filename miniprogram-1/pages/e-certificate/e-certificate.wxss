.page {
  min-height: 100vh;
  background: #f2f5f9;
}

.page-scroll {
  height: 100vh;
  padding: 24rpx 24rpx 48rpx;
}

.section {
  padding: 28rpx 24rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 8rpx 24rpx rgba(30, 41, 59, 0.04);
}

.section-head {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #0f172a;
}

.section-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #64748b;
}

.toolbar {
  margin-bottom: 20rpx;
}

.add-btn {
  display: inline-block;
  padding: 16rpx 36rpx;
  border-radius: 44rpx;
  background: #123c63;
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.card {
  padding: 24rpx;
  border-radius: 20rpx;
  background: #f8fafc;
}

.card-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #0f172a;
}

.card-status {
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
}

.status-0 { background: rgba(251, 191, 36, 0.15); color: #92400e; }
.status-1 { background: rgba(59, 130, 246, 0.12); color: #1d4ed8; }
.status-2 { background: rgba(34, 197, 94, 0.12); color: #15803d; }
.status-3 { background: rgba(239, 68, 68, 0.12); color: #b91c1c; }

.card-meta {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #94a3b8;
}

.card-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #475569;
}

.card-reject {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #b91c1c;
}

.empty {
  padding: 48rpx;
  text-align: center;
  font-size: 24rpx;
  color: #94a3b8;
}

.overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 99;
}

.form-panel {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 28rpx 28rpx 0 0;
  padding: 32rpx 32rpx 64rpx;
  z-index: 100;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.form-panel.show {
  transform: translateY(0);
}

.form-title {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 28rpx;
  color: #0f172a;
}

.form-group {
  margin-bottom: 24rpx;
}

.label {
  font-size: 26rpx;
  font-weight: 600;
  color: #334155;
  margin-bottom: 12rpx;
  display: block;
}

.input, .picker, .picker-value {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  border-radius: 16rpx;
  background: #f8fafc;
  font-size: 26rpx;
  line-height: 80rpx;
  color: #0f172a;
}

.textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  background: #f8fafc;
  font-size: 26rpx;
}

.form-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 32rpx;
}

.btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
}

.btn.cancel {
  background: #f1f5f9;
  color: #64748b;
}

.btn.submit {
  background: #123c63;
  color: #fff;
}

.btn.submit.disabled {
  opacity: 0.6;
}
