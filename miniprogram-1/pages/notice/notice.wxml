<view class="page">
  <scroll-view class="page-scroll" scroll-y enable-flex>
    <view class="section">
      <view class="section-head">
        <view class="section-title">通知</view>
        <view class="section-desc">默认展示全部通知；输入关键词后只展示相关通知。</view>
      </view>

      <view class="notice-toolbar">
        <view class="search-box">
          <input
            class="search-input"
            value="{{keyword}}"
            placeholder="搜索标题或摘要"
            confirm-type="search"
            bindinput="handleKeywordInput"
            bindconfirm="handleSearchConfirm"
          />
          <view wx:if="{{keyword}}" class="clear-search" bindtap="handleClearKeyword">清空</view>
          <view class="search-button" bindtap="handleSearchConfirm">搜索</view>
        </view>
        <view class="sort-tabs">
          <view
            class="sort-tab {{sortBy === 'time' ? 'is-active' : ''}}"
            data-sort="time"
            bindtap="handleSortChange"
          >按时间</view>
          <view
            class="sort-tab {{sortBy === 'relevance' ? 'is-active' : ''}}"
            data-sort="relevance"
            bindtap="handleSortChange"
          >按相关度</view>
        </view>
      </view>

      <view wx:if="{{messages.length}}" class="message-list">
        <view
          class="message-card {{item.readStatus === 0 ? 'is-unread' : ''}}"
          wx:for="{{messages}}"
          wx:key="id"
          data-id="{{item.id}}"
          data-noticeid="{{item.noticeId}}"
          data-index="{{index}}"
          bindtap="handleMessageTap"
        >
          <view class="message-top">
            <view class="message-badges">
              <view wx:if="{{item.pinnedStatus === 1}}" class="message-pin-badge">置顶</view>
              <view class="message-status">{{item.readStatus === 0 ? '未读' : '已读'}}</view>
            </view>
            <view class="message-date">{{item.date}}</view>
          </view>
          <view class="message-title">{{item.title}}</view>
          <view class="message-summary">{{item.summary}}</view>
          <view class="message-actions">
            <view
              class="pin-action {{item.pinnedStatus === 1 ? 'is-pinned' : ''}}"
              data-id="{{item.id}}"
              data-pinned="{{item.pinnedStatus}}"
              data-index="{{index}}"
              catchtap="handlePinTap"
            >{{item.pinnedStatus === 1 ? '取消置顶' : '置顶'}}</view>
          </view>
        </view>
      </view>

      <view wx:else class="empty-card">{{keyword ? '没有找到相关通知' : '暂无通知'}}</view>
    </view>
  </scroll-view>
</view>
