.page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top right, rgba(190, 30, 45, 0.06), transparent 28%),
    linear-gradient(180deg, #faf5f0 0%, #f5f0eb 45%, #efe8e0 100%);
}

.page-scroll {
  height: 100vh;
  padding: 32rpx 24rpx 48rpx;
}

.section {
  padding: 28rpx 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.88);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.section-head {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2c2c2c;
}

.section-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #6a6a6a;
}

.message-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.message-card {
  padding: 24rpx;
  border-radius: 20rpx;
  background: #faf5f0;
}

.is-unread {
  background: linear-gradient(180deg, #fef9f6 0%, #fdf0ec 100%);
  border-left: 4rpx solid #BE1E2D;
}

.message-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.message-badges {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.message-pin-badge {
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  color: #BE1E2D;
  background: rgba(190, 30, 45, 0.1);
}

.message-status {
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  color: #6a6a6a;
  background: rgba(0, 0, 0, 0.04);
}

.message-date {
  font-size: 22rpx;
  color: #b0b0b0;
}

.message-title {
  margin-top: 14rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #2c2c2c;
}

.message-summary {
  margin-top: 10rpx;
  font-size: 23rpx;
  line-height: 1.7;
  color: #6a6a6a;
}

.message-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 18rpx;
}

.pin-action {
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #BE1E2D;
  background: rgba(190, 30, 45, 0.08);
}

.pin-action.is-pinned {
  color: #8a8a8a;
  background: #e8e0d8;
}

.notice-toolbar {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 22rpx;
}

.search-box {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx;
  border-radius: 20rpx;
  background: #f5f0eb;
}

.search-input {
  flex: 1;
  height: 56rpx;
  padding: 0 16rpx;
  border-radius: 14rpx;
  background: #ffffff;
  font-size: 24rpx;
  color: #2c2c2c;
}

.clear-search,
.search-button {
  flex-shrink: 0;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.clear-search {
  color: #8a8a8a;
  background: #e0d8d0;
}

.search-button {
  color: #ffffff;
  background: #BE1E2D;
}

.sort-tabs {
  display: flex;
  gap: 12rpx;
}

.sort-tab {
  flex: 1;
  padding: 16rpx 0;
  border-radius: 999rpx;
  text-align: center;
  font-size: 23rpx;
  color: #6a6a6a;
  background: #f0e8e0;
}

.sort-tab.is-active {
  color: #ffffff;
  background: linear-gradient(135deg, #BE1E2D, #D43A4A);
  box-shadow: 0 6rpx 16rpx rgba(190, 30, 45, 0.2);
}

.empty-card {
  padding: 24rpx;
  border-radius: 20rpx;
  background: #faf5f0;
  font-size: 24rpx;
  color: #6a6a6a;
}
