.page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top right, rgba(56, 189, 248, 0.18), transparent 28%),
    linear-gradient(180deg, #f6fbff 0%, #f2f5f9 45%, #edf2f7 100%);
}

.page-scroll {
  height: 100vh;
  padding: 32rpx 24rpx 48rpx;
}

.section {
  padding: 28rpx 24rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.84);
  box-shadow: 0 18rpx 40rpx rgba(30, 41, 59, 0.06);
}

.section-head {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #0f172a;
}

.section-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #64748b;
}

.message-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.message-card {
  padding: 24rpx;
  border-radius: 24rpx;
  background: #f8fafc;
}

.is-unread {
  background: linear-gradient(180deg, #f8fbff 0%, #eef6ff 100%);
}

.message-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.message-badges {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.message-pin-badge {
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  color: #92400e;
  background: rgba(251, 191, 36, 0.2);
}

.message-status {
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  color: #155e75;
  background: rgba(34, 211, 238, 0.18);
}

.message-date {
  font-size: 22rpx;
  color: #94a3b8;
}

.message-title {
  margin-top: 14rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #0f172a;
}

.message-summary {
  margin-top: 10rpx;
  font-size: 23rpx;
  line-height: 1.7;
  color: #475569;
}

.message-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 18rpx;
}

.pin-action {
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #2563eb;
  background: rgba(37, 99, 235, 0.1);
}

.pin-action.is-pinned {
  color: #64748b;
  background: #e2e8f0;
}

.empty-card {
  padding: 24rpx;
  border-radius: 24rpx;
  background: #f8fafc;
  font-size: 24rpx;
  color: #475569;
}

.notice-toolbar {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 22rpx;
}

.search-box {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx;
  border-radius: 22rpx;
  background: #f1f5f9;
}

.search-input {
  flex: 1;
  height: 56rpx;
  padding: 0 16rpx;
  border-radius: 16rpx;
  background: #ffffff;
  font-size: 24rpx;
  color: #0f172a;
}

.clear-search,
.search-button {
  flex-shrink: 0;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.clear-search {
  color: #64748b;
  background: #e2e8f0;
}

.search-button {
  color: #ffffff;
  background: #2563eb;
}

.sort-tabs {
  display: flex;
  gap: 12rpx;
}

.sort-tab {
  flex: 1;
  padding: 16rpx 0;
  border-radius: 999rpx;
  text-align: center;
  font-size: 23rpx;
  color: #475569;
  background: #eef2f7;
}

.sort-tab.is-active {
  color: #ffffff;
  background: linear-gradient(135deg, #2563eb, #06b6d4);
  box-shadow: 0 10rpx 22rpx rgba(37, 99, 235, 0.18);
}
