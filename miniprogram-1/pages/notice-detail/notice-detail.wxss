.page {
  min-height: 100vh;
  background: #f5f0eb;
}

.page-scroll {
  height: 100vh;
  padding: 24rpx 24rpx 48rpx;
  box-sizing: border-box;
}

.detail-card {
  padding: 32rpx 28rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.meta-pill {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #1A3C6A;
  background: rgba(26, 60, 106, 0.08);
}

.priority {
  color: #BE1E2D;
  background: rgba(190, 30, 45, 0.08);
}

.tag {
  color: #1A3C6A;
  background: rgba(26, 60, 106, 0.06);
}

.title {
  margin-top: 26rpx;
  font-size: 36rpx;
  line-height: 1.35;
  font-weight: 800;
  color: #2c2c2c;
}

.time {
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #b0b0b0;
}

.summary {
  margin-top: 20rpx;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  background: #faf6f3;
  font-size: 24rpx;
  line-height: 1.7;
  color: #6a6a6a;
}

.divider {
  margin: 28rpx 0;
  height: 1rpx;
  background: #f0e8e0;
}

.content {
  font-size: 26rpx;
  line-height: 1.8;
  color: #2c2c2c;
}

.attachment-card {
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: 18rpx;
  background: rgba(26, 60, 106, 0.04);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.attachment-label {
  font-size: 24rpx;
  color: #1A3C6A;
  font-weight: 500;
}

.attachment-btn {
  padding: 10rpx 24rpx;
  border-radius: 999rpx;
  background: #1A3C6A;
  color: #fff;
  font-size: 22rpx;
}

.read-time {
  margin-top: 24rpx;
  font-size: 22rpx;
  color: #c0b8b0;
  text-align: center;
}

.feedback-section {
  margin-top: 20rpx;
  padding: 28rpx 24rpx;
  border-radius: 24rpx;
  background: #faf6f3;
}

.feedback-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #2c2c2c;
  margin-bottom: 20rpx;
}

.feedback-radio {
  margin-bottom: 20rpx;
}

.feedback-radio-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 14rpx;
  font-size: 26rpx;
  color: #4a4a4a;
}

.feedback-textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  background: #fff;
  font-size: 24rpx;
  color: #2c2c2c;
  border: 1rpx solid #e8e0d8;
}

.feedback-submit {
  margin-top: 20rpx;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 38rpx;
  background: #BE1E2D;
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
  text-align: center;
}

.feedback-list {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.feedback-item {
  padding: 20rpx;
  border-radius: 16rpx;
  background: #fff;
}

.feedback-item-top {
  display: flex;
  justify-content: space-between;
  font-size: 22rpx;
  color: #b0b0b0;
  margin-bottom: 10rpx;
}

.feedback-item-content {
  font-size: 24rpx;
  color: #4a4a4a;
  line-height: 1.6;
}

.feedback-item-status {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #1A3C6A;
}

.empty-card {
  text-align: center;
  padding: 60rpx;
  font-size: 24rpx;
  color: #b0b0b0;
}
