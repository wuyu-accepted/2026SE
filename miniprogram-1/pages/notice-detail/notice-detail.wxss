.page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top right, rgba(56, 189, 248, 0.18), transparent 28%),
    linear-gradient(180deg, #f6fbff 0%, #f2f5f9 45%, #edf2f7 100%);
}

.page-scroll {
  height: 100vh;
  padding: 32rpx 24rpx 48rpx;
  box-sizing: border-box;
}

.detail-card,
.empty-card {
  padding: 32rpx 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 18rpx 40rpx rgba(30, 41, 59, 0.06);
}

.meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.meta-pill {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #155e75;
  background: rgba(34, 211, 238, 0.18);
}

.priority {
  color: #92400e;
  background: rgba(251, 191, 36, 0.18);
}

.tag {
  color: #6d28d9;
  background: rgba(167, 139, 250, 0.18);
}

.title {
  margin-top: 26rpx;
  font-size: 38rpx;
  line-height: 1.35;
  font-weight: 800;
  color: #0f172a;
}

.time,
.read-time {
  margin-top: 16rpx;
  font-size: 23rpx;
  color: #94a3b8;
}

.summary {
  margin-top: 24rpx;
  padding: 22rpx;
  border-radius: 20rpx;
  font-size: 25rpx;
  line-height: 1.7;
  color: #475569;
  background: #f8fafc;
}

.divider {
  height: 1rpx;
  margin: 28rpx 0;
  background: #e2e8f0;
}

.content {
  white-space: pre-wrap;
  font-size: 28rpx;
  line-height: 1.85;
  color: #1e293b;
}

.empty-card {
  font-size: 26rpx;
  color: #64748b;
}
