<view class="page">
  <scroll-view class="page-scroll" scroll-y enable-flex>
    <view wx:if="{{detail}}" class="detail-card">
      <view class="meta-row">
        <view class="meta-pill">{{detail.noticeType}}</view>
        <view class="meta-pill priority">{{detail.priorityText}}</view>
        <view wx:if="{{detail.tag}}" class="meta-pill tag">{{detail.tag}}</view>
      </view>

      <view class="title">{{detail.title}}</view>
      <view class="time">发布时间：{{detail.publishText || '暂未记录'}}</view>

      <view wx:if="{{detail.summary}}" class="summary">
        {{detail.summary}}
      </view>

      <view class="divider"></view>

      <view wx:if="{{articleUrl}}" class="article-card" bindtap="openArticle">
        <view class="article-card-icon">🔗</view>
        <view class="article-card-text">
          <view class="article-card-title">查看原文</view>
          <view class="article-card-desc">点击复制链接，在浏览器中打开公众号文章</view>
        </view>
        <view class="article-card-action">复制</view>
      </view>

      <view wx:else class="content">{{detail.content || '暂无正文'}}</view>

      <view wx:if="{{detail.attachmentFileId}}" class="attachment-card" bindtap="downloadAttachment">
        <view>
          <view class="attachment-title">通知附件</view>
          <view class="attachment-desc">点击下载并打开附件文件</view>
        </view>
        <view class="attachment-action">下载</view>
      </view>

      <view wx:if="{{detail.readText}}" class="read-time">已读时间：{{detail.readText}}</view>

      <view class="feedback-section">
        <view class="feedback-title">疑问反馈</view>
        <radio-group class="feedback-type-row" bindchange="onFeedbackTypeChange">
          <label class="feedback-type">
            <radio value="ordinary" checked="{{feedbackType === 'ordinary'}}" />普通问题
          </label>
          <label class="feedback-type">
            <radio value="private" checked="{{feedbackType === 'private'}}" />私密问题
          </label>
        </radio-group>
        <textarea
          class="feedback-input"
          value="{{feedbackContent}}"
          maxlength="2000"
          placeholder="请输入你对该通知的疑问"
          bindinput="onFeedbackContentInput"
        />
        <button class="feedback-submit" loading="{{submittingFeedback}}" bindtap="submitFeedback">提交反馈</button>

        <view wx:if="{{feedbacks.length}}" class="feedback-history">
          <view class="feedback-history-title">我的反馈记录</view>
          <view class="feedback-card" wx:for="{{feedbacks}}" wx:key="id">
            <view class="feedback-card-top">
              <view class="feedback-pill">{{item.typeText}}</view>
              <view class="feedback-status">{{item.statusText}}</view>
            </view>
            <view class="feedback-content">{{item.content}}</view>
            <view class="feedback-time">{{item.createdText}}</view>
          </view>
        </view>
      </view>
    </view>

    <view wx:elif="{{loading}}" class="empty-card">正在加载通知详情...</view>
    <view wx:else class="empty-card">通知详情不可用</view>
  </scroll-view>
</view>
