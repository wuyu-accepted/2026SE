.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f6fbff 0%, #edf2f7 100%);
}

.page-scroll {
  height: 100vh;
  padding: 32rpx 24rpx 48rpx;
  box-sizing: border-box;
}

.section {
  padding: 28rpx 24rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.9);
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #0f172a;
}

.section-desc,
.empty-card {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #64748b;
}

.feedback-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 24rpx;
}

.feedback-card,
.empty-card {
  padding: 24rpx;
  border-radius: 24rpx;
  background: #f8fafc;
}

.feedback-top {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.notice-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #0f172a;
}

.feedback-time {
  flex-shrink: 0;
  font-size: 22rpx;
  color: #94a3b8;
}

.feedback-content {
  margin-top: 14rpx;
  font-size: 25rpx;
  line-height: 1.7;
  color: #334155;
}

.feedback-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 18rpx;
}
