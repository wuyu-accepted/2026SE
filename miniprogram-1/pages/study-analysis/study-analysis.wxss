.page {
  min-height: 100vh;
  background: #f2f5f9;
  padding: 40rpx;
}

.header {
  padding: 16rpx 0 24rpx;
}

.title {
  font-size: 38rpx;
  font-weight: 800;
  color: #0f172a;
}

.sub {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.6;
}

.section {
  background: #ffffff;
  border-radius: 28rpx;
  padding: 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 22rpx;
}

.section-last {
  margin-bottom: 0;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 16rpx;
}

.major {
  font-size: 24rpx;
  color: #475569;
  margin-bottom: 16rpx;
}

.grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.grid-item {
  background: #f8fafc;
  border-radius: 22rpx;
  padding: 18rpx;
  border: 2rpx solid rgba(15, 23, 42, 0.06);
}

.grid-item:active {
  border-color: rgba(37, 99, 235, 0.35);
}

.grid-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #0f172a;
}

.grid-row {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #64748b;
}

.grid-remaining {
  margin-top: 10rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #123c63;
}

.warn {
  margin-top: 14rpx;
  font-size: 22rpx;
  color: #b45309;
  line-height: 1.6;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.row {
  background: #f8fafc;
  border-radius: 22rpx;
  padding: 18rpx;
}

.row-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #0f172a;
}

.row-meta {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #64748b;
}

.empty {
  font-size: 24rpx;
  color: #94a3b8;
  text-align: center;
  padding: 18rpx 0;
}

.form {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.textarea {
  border-radius: 20rpx;
  background: #f8fafc;
  padding: 18rpx;
  font-size: 26rpx;
  color: #0f172a;
  min-height: 220rpx;
}

.divider {
  height: 1rpx;
  background: rgba(15, 23, 42, 0.06);
  margin: 24rpx 0;
}

.small-title {
  font-size: 24rpx;
  font-weight: 700;
  color: #0f172a;
  margin-top: 10rpx;
  margin-bottom: 12rpx;
}

.chips {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.chip {
  padding: 10rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #123c63;
  background: rgba(18, 60, 99, 0.10);
}

.chip.gray {
  color: #475569;
  background: rgba(71, 85, 105, 0.10);
}

.elective-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 10rpx;
}

.elective-item {
  padding: 18rpx;
  border-radius: 22rpx;
  background: #f8fafc;
  border: 2rpx solid rgba(15, 23, 42, 0.06);
}

.elective-item:active {
  border-color: rgba(37, 99, 235, 0.35);
}

.elective-name {
  font-size: 26rpx;
  font-weight: 700;
  color: #0f172a;
}

.elective-meta {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #64748b;
}

.elective-preview {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #475569;
  line-height: 1.6;
}

.input {
  border-radius: 20rpx;
  background: #f8fafc;
  box-sizing: border-box;
  height: 76rpx;
  line-height: 76rpx;
  padding: 0 22rpx;
  font-size: 26rpx;
  color: #0f172a;
}

.picker {
  border-radius: 20rpx;
  background: #f8fafc;
  box-sizing: border-box;
  min-height: 76rpx;
  line-height: 40rpx;
  padding: 18rpx 22rpx;
  font-size: 26rpx;
  color: #0f172a;
}

.primary-btn {
  border-radius: 999rpx;
  background: #2563eb;
  color: #ffffff;
  font-size: 28rpx;
  width: 60%;
  min-height: 64rpx;
  line-height: 64rpx;
}

.danger-btn {
  margin-top: 18rpx;
  border-radius: 999rpx;
  background: rgba(239, 68, 68, 0.12);
  color: #ef4444;
  font-size: 26rpx;
  min-height: 64rpx;
  line-height: 64rpx;
}
