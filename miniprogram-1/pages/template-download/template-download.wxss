.page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top left, rgba(14, 165, 233, 0.16), transparent 24%),
    linear-gradient(180deg, #f6fbff 0%, #f2f5f9 45%, #edf2f7 100%);
}

.page-scroll {
  height: 100vh;
  padding: 32rpx 24rpx 48rpx;
}

.section {
  margin-top: 28rpx;
  padding: 28rpx 24rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.84);
  box-shadow: 0 18rpx 40rpx rgba(30, 41, 59, 0.06);
}

.section-head {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #0f172a;
}

.section-desc,
.template-desc,
.empty-card {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #475569;
}

.template-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.template-card,
.empty-card {
  padding: 24rpx;
  border-radius: 24rpx;
  background: #f8fafc;
}

.template-card {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.template-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #0f172a;
}

.template-format {
  flex-shrink: 0;
  align-self: flex-start;
  font-size: 20rpx;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  color: #155e75;
  background: rgba(34, 211, 238, 0.14);
}
.template-main {
  min-width: 0;
}

.template-target {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #2563eb;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.tag-chip {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  color: #334155;
  background: rgba(148, 163, 184, 0.16);
}
