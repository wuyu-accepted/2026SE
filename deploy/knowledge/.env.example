# 复制为 deploy/knowledge/.env 后按部署机器修改。
# 默认值面向“本地开源一键部署”：PostgreSQL + 后端 + 前端 Nginx。

COMPOSE_PROJECT_NAME=2026se-knowledge

# 端口
FRONTEND_PORT=8080
BACKEND_PORT=18080

# 数据库
DB_NAME=ruc_platform
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432

# Spring
SPRING_PROFILES_ACTIVE=postgres
SERVER_PORT=18080
WECHAT_MINIAPP_APPID=
WECHAT_MINIAPP_SECRET=

# 持久化路径（容器内路径通常无需改；宿主机目录由脚本创建在 runtime/ 下）
FILE_UPLOAD_PATH=/data/ruc-platform/uploads
KNOWLEDGE_SEARCH_INDEX_PATH=/data/ruc-platform/lucene/knowledge
KNOWLEDGE_VECTOR_INDEX_PATH=/data/ruc-platform/lucene/knowledge-vectors

# 异步索引
KNOWLEDGE_INDEXING_ENABLED=true
KNOWLEDGE_INDEXING_MAX_RETRY=3
KNOWLEDGE_INDEXING_BATCH_SIZE=3
KNOWLEDGE_INDEXING_FIXED_DELAY_MS=30000

# OCR：增强镜像内置 tesseract 与简体中文语言包；不需要 OCR 可设为 false。
KNOWLEDGE_OCR_ENABLED=true
KNOWLEDGE_OCR_COMMAND=tesseract
KNOWLEDGE_OCR_LANGUAGE=chi_sim+eng
KNOWLEDGE_OCR_TIMEOUT_SECONDS=120

# LaTeX：默认关闭，避免部署时强依赖大型 TeX 发行版。
# 如部署机或自定义镜像已安装 tectonic/xelatex，可设为 true 并填写命令。
KNOWLEDGE_LATEX_ENABLED=false
KNOWLEDGE_LATEX_COMMAND=tectonic
KNOWLEDGE_LATEX_TIMEOUT_SECONDS=120

# 语义检索：默认启用本地 hash fallback；放入 ONNX 模型后自动走本地模型。
KNOWLEDGE_SEMANTIC_ENABLED=true
KNOWLEDGE_SEMANTIC_VECTOR_INDEX_ENABLED=true
KNOWLEDGE_ONNX_MODEL_PATH=/opt/ruc-platform/models/embedding/model.onnx
KNOWLEDGE_ONNX_TOKENIZER_PATH=/opt/ruc-platform/models/embedding/vocab.txt
KNOWLEDGE_ONNX_INPUT_IDS_NAME=input_ids
KNOWLEDGE_ONNX_ATTENTION_MASK_NAME=attention_mask
KNOWLEDGE_ONNX_POOLING=mean
KNOWLEDGE_ONNX_MAX_TOKENS=128

# 同义词词库：可选，留空时使用代码内置 + 数据库维护的同义词。
KNOWLEDGE_SYNONYM_PATH=
